# URL del pooler de Supabase (transaction mode, puerto 6543).
# En Vercel define esta variable en: Settings > Environment Variables.
# Formato: postgresql://postgres.<REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.<TU-REF>:TU-PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Entorno: "production" en Vercel, "development" en local.
NODE_ENV=production

PORT=3000
CORS_ORIGIN=https://TU-DOMINIO.vercel.app

# (Opcional) Límites del pool de conexiones para serverless.
# PG_MAX_CONNECTIONS=5

# Credenciales de Supabase (si las usas en el cliente/servidor).
SUPABASE_URL=https://<TU-REF>.supabase.co
SUPABASE_ANON_KEY=TU-ANON-KEY

# Auth: secreto para firmar los JWT de sesión. EN PRODUCCIÓN usa un valor fuerte y único.
JWT_SECRET=cambia-esto-por-un-secreto-fuerte-y-largo
JWT_EXPIRES_IN=7d

# (Opcional) El primer usuario registrado es admin automáticamente.
# También puedes forzar admin a este email sin importar el orden.
ADMIN_EMAIL=admin@tudominio.com
